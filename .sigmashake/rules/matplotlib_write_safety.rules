# matplotlib_write_safety.rules
# Technology: matplotlib | Capability: write

rule matplotlib-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "plt.xkcd()"
  MESSAGE "Blocked an unsafe pattern in matplotlib. Use the recommended best practices for 2025/2026."
}

rule matplotlib-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "pylab"
  MESSAGE "You are using an outdated API for matplotlib. Please upgrade to the newer API."
}
